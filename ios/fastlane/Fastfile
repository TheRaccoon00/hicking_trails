default_platform(:ios)

platform :ios do
  desc "Upload to TestFlight"
  lane :beta do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"],
      is_key_content_base64: false
    )

    # Determine the project root (GITHUB_WORKSPACE is most reliable in CI)
    project_root = ENV['GITHUB_WORKSPACE'] || File.expand_path("../..", Dir.pwd)
    
    # Search for the IPA in the build directory
    ipa_search_pattern = File.join(project_root, "build/ios/ipa/*.ipa")
    ipa_file = Dir.glob(ipa_search_pattern).first

    unless ipa_file
      UI.message("Project root: #{project_root}")
      UI.message("Search pattern: #{ipa_search_pattern}")
      UI.user_error!("Could not find any IPA file in the build directory. Please check the 'Build IPA' step output.")
    end

    # Ensure we use an absolute path
    ipa_file = File.expand_path(ipa_file)

    # Rename the file if it contains spaces, as it often breaks CI tools
    if File.basename(ipa_file).include?(" ")
      UI.message("Renaming IPA to remove spaces: #{ipa_file}")
      temp_ipa_path = File.join(File.dirname(ipa_file), "app.ipa")
      File.rename(ipa_file, temp_ipa_path)
      ipa_file = temp_ipa_path
    end

    UI.message("Using IPA at: #{ipa_file}")

    upload_to_testflight(
      ipa: ipa_file,
      skip_waiting_for_build_processing: true
    )
  end
end