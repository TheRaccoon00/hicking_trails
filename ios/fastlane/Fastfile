default_platform(:ios)

platform :ios do
  desc "Upload to TestFlight"
  lane :beta do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"],
      is_key_content_base64: false
    )

    # Search for the IPA in multiple possible locations
    search_paths = [
      "../build/ios/ipa/*.ipa",
      "../../build/ios/ipa/*.ipa"
    ]
    if ENV['GITHUB_WORKSPACE']
      search_paths << File.join(ENV['GITHUB_WORKSPACE'], "build/ios/ipa/*.ipa")
    end

    ipa_file = nil
    search_paths.each do |path|
      ipa_file = Dir.glob(path).first
      break if ipa_file
    end

    unless ipa_file
      UI.message("Searched paths: #{search_paths.join(', ')}")
      UI.user_error!("Could not find any IPA file in the build directory. Please check the 'Build IPA' step output.")
    end

    # Rename the file if it contains spaces, as it often breaks CI tools
    if ipa_file.include?(" ")
      UI.message("Renaming IPA to remove spaces: #{ipa_file}")
      temp_ipa_path = File.join(File.dirname(ipa_file), "app.ipa")
      File.rename(ipa_file, temp_ipa_path)
      ipa_file = temp_ipa_path
    end

    UI.message("Found IPA at: #{ipa_file}")

    upload_to_testflight(
      ipa: ipa_file,
      skip_waiting_for_build_processing: true
    )
  end
end